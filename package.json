{
  "name": "iobroker.frigate",
  "version": "2.2.1",
  "description": "Adapter for Frigate",
  "author": "TA2k <tombox2020@gmail.com>",
  "contributors": [
    "Bettman66",
    "iobroker-community-adapters <iobroker-community-adapters@gmx.de>"
  ],
  "homepage": "https://github.com/iobroker-community-adapters/ioBroker.frigate",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "frigate",
    "ki",
    "detection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iobroker-community-adapters/ioBroker.frigate.git"
  },
  "type": "module",
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/plugin-docker": "^1.0.1",
    "aedes": "^1.0.2",
    "axios": "^1.14.0",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.0",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "docker-compose.yaml",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json test/utils.test.js test/main.test.js --exit",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "lint": "eslint -c eslint.config.mjs",
    "translate": "translate-adapter",
    "release": "release-script --all",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "update-packages": "npx -y npm-check-updates"
  },
  "bugs": {
    "url": "https://github.com/iobroker-community-adapters/ioBroker.frigate/issues"
  },
  "readmeFilename": "README.md"
}
